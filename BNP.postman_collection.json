    {
      "name": "Booking",
      "item": [
        {
          "name": "Book a flight",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function isTokenExpired(token) {\r",
                  "    if (!token) return true;\r",
                  "    try {\r",
                  "        const base64Url = token.split('.')[1];\r",
                  "        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');\r",
                  "        const payload = JSON.parse(atob(base64));\r",
                  "        \r",
                  "        const now = Math.floor(Date.now() / 1000);\r",
                  "        return payload.exp < now;\r",
                  "    } catch (e) {\r",
                  "        return true;\r",
                  "    }\r",
                  "}\r",
                  "\r",
                  "const currentToken = pm.environment.get(\"bnp_current_token\");\r",
                  "if (!isTokenExpired(currentToken)) return;\r",
                  "\r",
                  "pm.sendRequest({\r",
                  "    url: 'http://localhost:8080/auth/login',\r",
                  "    method: 'POST',\r",
                  "    header: {\r",
                  "        'Content-Type': 'application/json'\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: 'raw',\r",
                  "        raw: JSON.stringify({\r",
                  "            \"username\": \"test\",\r",
                  "            \"password\": \"test\"\r",
                  "        })\r",
                  "    }\r",
                  "}, function (err, response) {\r",
                  "    if (err) {\r",
                  "        console.error(err);\r",
                  "    } else {\r",
                  "        const textResponse = response.text();\r",
                  "        pm.environment.set(\"bnp_current_token\", textResponse);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bnp_current_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"scheduledFlightId\": 1,\r\n    \"seats\": 99\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/protected/flight-booking/book",
              "protocol": "http",
